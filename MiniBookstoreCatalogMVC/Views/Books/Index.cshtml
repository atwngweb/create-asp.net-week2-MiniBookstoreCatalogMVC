@model List<MiniBookstoreCatalogMVC.ViewModels.BookListItemViewModel>

@{
    ViewData["Title"] = "Danh Sách Sách";
}

<div class="container mt-4">
    <h2>📚 Danh Sách Sách</h2>
    <p>Tổng cộng: <strong>@Model.Count</strong> đầu sách</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên sách</th>
                <th>Tác giả</th>
                <th>Thể loại</th>
                <th>Giá (VND)</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model) {
                var rowClass = book.StockStatus switch
                {
                    "Out Of Stock" => "table-danger",
                    "Low Stock" => "table-warning",
                    _ => ""
                };
                <tr class="@rowClass">
                    <td>@book.Id</td>
                    <td><strong>@book.Title</strong></td>
                    <td>@book.Author</td>
                    <td><span class="badge bg-secondary">@book.Category</span></td>
                    <td>@book.Price.ToString("N0") đ</td>
                    <td>@book.StockQuantity</td>
                    <td>
                        @if (book.StockStatus == "Out Of Stock")
                        {
                            <span class="badge bg-danger">Out Of Stock</span>
                        }
                        else if (book.StockStatus == "Low Stock")
                        {
                            <span class="badge bg-warning text-dark">Low Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-success">In Stock</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@book.Id"
                           class="btn btn-sm btn-outline-primary">Xem</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Books" asp-action="Stats" class="btn btn-success">
        📊 Xem thống kê
    </a>
</div>